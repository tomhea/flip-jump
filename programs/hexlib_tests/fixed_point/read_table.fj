// Tests hex.read_table - runtime-indexed LUT access (the documented entry layout).
// The sine_table below was emitted by:
//   generate_sine_lut_fj('sine_table', count=8, fraction_bits=16, entry_nibbles=8)  (the doom-flipjump LUT generator)

stl.startup_and_init_all

hex.read_table 8, res8, sine_table, 2, i1    // sin(2pi/8) = 0.7071 (16.16)
hex.print_as_digit 8, res8, 0
stl.output '\n'

hex.read_table 8, res8, sine_table, 2, i2    // sin(2pi*2/8) = 1.0
hex.print_as_digit 8, res8, 0
stl.output '\n'

hex.read_table 8, res8, sine_table, 2, i6    // sin(2pi*6/8) = -1.0
hex.print_as_digit 8, res8, 0
stl.output '\n'

hex.read_table 8, res8, sine_table, 2, i0    // sin(0) = 0
hex.print_as_digit 8, res8, 0
stl.output '\n'

stl.loop

// LUT "sine_table": 8 entries of 8 nibbles (a generated table, inlined)
sine_table:
    hex.vec 8, 0x0
    hex.vec 8, 0xb505
    hex.vec 8, 0x10000
    hex.vec 8, 0xb505
    hex.vec 8, 0x0
    hex.vec 8, 0xffff4afb
    hex.vec 8, 0xffff0000
    hex.vec 8, 0xffff4afb

i0: hex.vec 2, 0
i1: hex.vec 2, 1
i2: hex.vec 2, 2
i6: hex.vec 2, 6
res8: hex.vec 8
