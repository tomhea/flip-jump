// Tests hex.fixed_mul - signed Q-format fixed-point multiply (16.16 and 8.8).
// Expected outputs are computed by the host-side reference: ((a*b) >> 4f) mod 2^4n (signed).

stl.startup_and_init_all

hex.fixed_mul 8, 4, res8, a1, b1     // 1.5 * 2.0 = 3.0
hex.print_as_digit 8, res8, 0
stl.output '\n'

hex.fixed_mul 8, 4, res8, a2, b2     // -1.5 * 2.0 = -3.0
hex.print_as_digit 8, res8, 0
stl.output '\n'

hex.fixed_mul 8, 4, res8, a3, b3     // -1.5 * -2.0 = 3.0
hex.print_as_digit 8, res8, 0
stl.output '\n'

hex.fixed_mul 8, 4, res8, a4, b4     // 16384.0 * 4.0 - wraps modulo 2^32
hex.print_as_digit 8, res8, 0
stl.output '\n'

hex.fixed_mul 8, 4, res8, a5, b5     // 0.5 * 0.5 = 0.25
hex.print_as_digit 8, res8, 0
stl.output '\n'

hex.fixed_mul 4, 2, res4, p1, q1     // 8.8: 2.5 * -2.0 = -5.0
hex.print_as_digit 4, res4, 0
stl.output '\n'

hex.fixed_mul 8, 4, m1, m1, b1       // dst aliases a: 1.5 * 2.0 = 3.0 (in place)
hex.print_as_digit 8, m1, 0
stl.output '\n'

hex.fixed_mul 8, 4, res8, n1, n1     // -0.5 * -0.5 = 0.25 (both sign-extended, b aliases a)
hex.print_as_digit 8, res8, 0
stl.output '\n'

stl.loop

a1: hex.vec 8, 0x00018000
b1: hex.vec 8, 0x00020000
a2: hex.vec 8, 0xFFFE8000
b2: hex.vec 8, 0x00020000
a3: hex.vec 8, 0xFFFE8000
b3: hex.vec 8, 0xFFFE0000
a4: hex.vec 8, 0x40000000
b4: hex.vec 8, 0x00040000
a5: hex.vec 8, 0x00008000
b5: hex.vec 8, 0x00008000
p1: hex.vec 4, 0x0280
q1: hex.vec 4, 0xFE00
m1: hex.vec 8, 0x00018000
n1: hex.vec 8, 0xFFFF8000
res8: hex.vec 8
res4: hex.vec 4
