// Tests the DOOM-prep helpers: hex.abs, hex.fill_bytes, hex.copy_bytes,
// hex.read_table_byte (+ a generated byte-LUT table, inlined below).

hw = w/4

stl.startup_and_init_all

hex.abs 8, a_pos                     // 5 -> 5
hex.print_as_digit 8, a_pos, 0
stl.output '\n'
hex.abs 8, a_neg                     // -5 -> 5
hex.print_as_digit 8, a_neg, 0
stl.output '\n'
hex.abs 8, a_zero                    // 0 -> 0
hex.print_as_digit 8, a_zero, 0
stl.output '\n'
hex.abs 8, a_min                     // -2^31 stays itself (two's complement)
hex.print_as_digit 8, a_min, 0
stl.output '\n'

hex.fill_bytes buf_ptr, six, x_byte  // "xxxxxx"
hex.print_ptr_text buf_ptr, six
stl.output '\n'

hex.copy_bytes buf_ptr, src_ptr, five   // "HELLO" over the x's
hex.print_ptr_text buf_ptr, six         // -> "HELLOx"
stl.output '\n'

hex.read_table_byte b, byte_table, 2, i0
hex.print b
hex.read_table_byte b, byte_table, 2, i2
hex.print b
hex.read_table_byte b, byte_table, 2, i3
hex.print b
stl.output '\n'

stl.loop

a_pos:  hex.vec 8, 5
a_neg:  hex.vec 8, 0xFFFFFFFB
a_zero: hex.vec 8, 0
a_min:  hex.vec 8, 0x80000000

buf_ptr: hex.vec hw, buf
src_ptr: hex.vec hw, src_buf
six:     hex.vec hw, 6
five:    hex.vec hw, 5
x_byte:  hex.vec 2, 'x'

i0: hex.vec 2, 0
i2: hex.vec 2, 2
i3: hex.vec 2, 3
b:  hex.vec 2

// byte LUT "byte_table": 4 packed-byte entries (a generated table, inlined)
byte_table:
    ;0x41 * dw
    ;0x42 * dw
    ;0x43 * dw
    ;0x44 * dw

src_buf:   // "HELLO" as packed bytes
    ;'H' * dw
    ;'E' * dw
    ;'L' * dw
    ;'L' * dw
    ;'O' * dw

buf: hex.vec 16   // a 16-op writable byte buffer
