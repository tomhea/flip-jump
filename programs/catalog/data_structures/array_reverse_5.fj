// Array Reverse 5 (#0381)

// Reads 5 decimals (each own line) and prints them in reverse order, one per line.

main

def main @ err < arr {
    stl.startup_and_init_all
    rep(5, i) hex.input_dec_uint 4, arr + i*dw*4, err
    rep(5, i) pc arr + (4-i)*dw*4
  err:
    stl.loop
}

// Print one 4-hex cell as decimal + newline.
def pc c {
    hex.print_dec_uint 4, c
    stl.output '\n'
}

arr: hex.vec 4*5
