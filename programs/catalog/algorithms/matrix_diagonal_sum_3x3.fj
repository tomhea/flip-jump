// Matrix Diagonal Sum 3x3 (#0566)

// Reads 9 decimals (3×3 row-major). Prints the sum of the main diagonal `a[0][0] + a[1][1] + a[2][2]` as decimal + `\n`.

main

def main @ err < arr, sum {
    stl.startup_and_init_all
    rep(9, i) hex.input_dec_uint 4, arr + i*dw*4, err
    hex.mov 4, sum, arr + 0*dw*4
    hex.add 4, sum, arr + 4*dw*4
    hex.add 4, sum, arr + 8*dw*4
    hex.print_dec_uint 4, sum
    stl.output '\n'
  err:
    stl.loop
}

arr: hex.vec 4*9
sum: hex.vec 4, 0
