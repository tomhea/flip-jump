    hex.set w/4, eqptr, buf
    next_byte_is eqptr, 'B', no
    next_byte_is eqptr, 'r', no
    next_byte_is eqptr, 'a', no
    next_byte_is eqptr, 'v', no
    next_byte_is eqptr, 'o', no
    ;yes
}
