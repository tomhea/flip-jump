// Checksum Xor (#1358)

// Reads a `\n`-terminated line ≤ 30 chars. Prints the XOR of all byte values (excluding `\n`) as two lowercase hex chars + `\n`.

main

def main @ err, loop, go, done < b, nl, x {
    stl.startup_and_init_all
    hex.zero 2, x
  loop:
    hex.input b
    hex.if0 2, b, done
    hex.cmp 2, b, nl, go, done, go
  go:
    hex.xor 2, x, b
    ;loop
  done:
    hex.print_as_digit 2, x, 0
    stl.output '\n'
  err:
    stl.loop
}

b: hex.vec 2
nl: hex.vec 2, '\n'
x: hex.vec 2
