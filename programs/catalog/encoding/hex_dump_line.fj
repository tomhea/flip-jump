// Hex Dump Line (#1342)

// Reads a `\n`-terminated line ≤ 16 chars. For each byte (excluding `\n`), prints its 2-char lowercase hex, with space separators between bytes, then `\n`. Example: input `hi\n` → output `68 69\n`. Empty input → just `\n`.

main

def main @ err, loop, go, fb, emit, done < b, nl, first {
    stl.startup_and_init_all
    bit.one first
  loop:
    hex.input b
    hex.if0 2, b, done
    hex.cmp 2, b, nl, go, done, go
  go:
    bit.if1 first, fb
    stl.output ' '
    ;emit
  fb:
    bit.zero first
  emit:
    print_hex_byte b
    ;loop
  done:
    stl.output '\n'
  err:
    stl.loop
}

// Print a byte register (hex.vec 2) as 2 lowercase hex chars (high nibble first).
def print_hex_byte b {
    hex.print_as_digit b + dw, 0
    hex.print_as_digit b, 0
}

b: hex.vec 2
nl: hex.vec 2, '\n'
first: bit.bit 1
