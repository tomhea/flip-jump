// Emoji Smiley Or Frown (#1372)

// Reads exactly one byte `0` or `1` followed by `\n`. Prints `:)\n` for `1`, `:(\n` for `0`.

main

def main @ smiley, frown, done < ch, onec {
    stl.startup
    bit.input ch
    bit.cmp 8, ch, onec, frown, smiley, frown
  smiley:
    stl.output ":)\n"
    ;done
  frown:
    stl.output ":(\n"
  done:
    stl.loop
}

ch: bit.vec 8, 0
onec: bit.vec 8, '1'
