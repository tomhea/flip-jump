// Rectangle Area (#0581)

// Reads two decimals `width` `height` (each own line, `0`-`100`). Prints `width * height` + `\n`.

main

def main < width, height, area, input_err {
    stl.startup_and_init_all
    hex.input_dec_uint 4, width, input_err
    hex.input_dec_uint 4, height, input_err
    hex.mul 4, area, width, height
    hex.print_dec_uint 4, area
    stl.output '\n'
    stl.loop
}

width: hex.vec 4, 0
height: hex.vec 4, 0
area: hex.vec 4, 0

input_err:
    stl.loop
