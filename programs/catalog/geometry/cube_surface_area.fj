// Cube Surface Area (#0586)

// Reads decimal side `0`-`20` + `\n`. Prints `6 * side * side` + `\n`.

main

def main < side, sq, area, six, input_err {
    stl.startup_and_init_all
    hex.input_dec_uint 4, side, input_err
    hex.mul 4, sq, side, side
    hex.mul 4, area, sq, six
    hex.print_dec_uint 4, area
    stl.output '\n'
    stl.loop
}

side: hex.vec 4, 0
sq: hex.vec 4, 0
area: hex.vec 4, 0
six: hex.vec 4, 6

input_err:
    stl.loop
