// Square Perimeter (#0609)

// Reads decimal side `0`-`100` + `\n`. Prints `4 * side` + `\n`.

main

def main < side, perim, input_err {
    stl.startup_and_init_all
    hex.input_dec_uint 4, side, input_err
    hex.mov 4, perim, side
    hex.add 4, perim, side
    hex.add 4, perim, perim
    hex.print_dec_uint 4, perim
    stl.output '\n'
    stl.loop
}

side: hex.vec 4, 0
perim: hex.vec 4, 0

input_err:
    stl.loop
