// Space To Tab (#0043)

// Reads stdin and replaces each space (` `) with `\t`; other bytes unchanged.

main

def main @ loop, is_space, not_space, end < ch, space, tab {
    stl.startup
  loop:
    bit.input ch
    bit.if0 8, ch, end
    bit.cmp 8, ch, space, not_space, is_space, not_space
  is_space:
    bit.print tab
    ;loop
  not_space:
    bit.print ch
    ;loop
  end:
    stl.loop
}

ch: bit.vec 8, 0
space: bit.vec 8, ' '
tab: bit.vec 8, '\t'
