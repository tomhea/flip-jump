// Print First Line (#0050)

// Reads stdin up to the first `\n` and prints only that line (including the `\n`).

main

def main @ loop, print_ch, end_with_nl, end < ch, nl {
    stl.startup
  loop:
    bit.input ch
    bit.if0 8, ch, end
    bit.cmp 8, ch, nl, print_ch, end_with_nl, print_ch
  print_ch:
    bit.print ch
    ;loop
  end_with_nl:
    bit.print nl
  end:
    stl.loop
}

ch: bit.vec 8, 0
nl: bit.vec 8, '\n'
