// Count Bytes (#0030)

// Reads all of stdin, prints the total byte count as a decimal integer followed by `\n`.

main

def main @ loop, end < ch, counter {
    stl.startup
  loop:
    bit.input ch
    bit.if0 8, ch, end
    bit.inc 16, counter
    ;loop
  end:
    bit.print_dec_uint 16, counter
    stl.output '\n'
    stl.loop
}

ch: bit.vec 8, 0
counter: bit.vec 16, 0
