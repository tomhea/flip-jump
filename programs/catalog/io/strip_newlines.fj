// Strip Newlines (#0036)

// Reads stdin and outputs all bytes except `\n`.

main

def main @ loop, print_ch, skip, end < ch, nl {
    stl.startup
  loop:
    bit.input ch
    bit.if0 8, ch, end
    bit.cmp 8, ch, nl, print_ch, skip, print_ch
  print_ch:
    bit.print ch
  skip:
    ;loop
  end:
    stl.loop
}

ch: bit.vec 8, 0
nl: bit.vec 8, '\n'
