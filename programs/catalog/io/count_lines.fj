// Count Lines (#0031)

// Reads all of stdin, prints the number of `\n` bytes seen as decimal + `\n`.

main

def main @ loop, inc_count, not_nl, end < ch, nl, counter {
    stl.startup
  loop:
    bit.input ch
    bit.if0 8, ch, end
    bit.cmp 8, ch, nl, not_nl, inc_count, not_nl
  inc_count:
    bit.inc 16, counter
  not_nl:
    ;loop
  end:
    bit.print_dec_uint 16, counter
    stl.output '\n'
    stl.loop
}

ch: bit.vec 8, 0
nl: bit.vec 8, '\n'
counter: bit.vec 16, 0
