// Input Then Thanks (#0053)

// Reads a single-line input and prints `Got it: <line>\nThank you!\n`.

main

def main @ loop, print_ch, end < ch, nl {
    stl.startup
    stl.output "Got it: "
  loop:
    bit.input ch
    bit.if0 8, ch, end
    bit.cmp 8, ch, nl, print_ch, end, print_ch
  print_ch:
    bit.print ch
    ;loop
  end:
    stl.output "\nThank you!\n"
    stl.loop
}

ch: bit.vec 8, 0
nl: bit.vec 8, '\n'
