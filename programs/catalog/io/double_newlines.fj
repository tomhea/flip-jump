// Double Newlines (#0051)

// Reads stdin and outputs each `\n` byte as two `\n`s; other bytes unchanged.

main

def main @ loop, is_nl, not_nl, end < ch, nl {
    stl.startup
  loop:
    bit.input ch
    bit.if0 8, ch, end
    bit.cmp 8, ch, nl, not_nl, is_nl, not_nl
  is_nl:
    bit.print nl
    bit.print nl
    ;loop
  not_nl:
    bit.print ch
    ;loop
  end:
    stl.loop
}

ch: bit.vec 8, 0
nl: bit.vec 8, '\n'
