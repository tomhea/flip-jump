// Strip Spaces (#0051)

// Reads stdin and outputs all bytes except space (` `).

main

def main @ loop, print_ch, skip, end < ch, space {
    stl.startup
  loop:
    bit.input ch
    bit.if0 8, ch, end
    bit.cmp 8, ch, space, print_ch, skip, print_ch
  print_ch:
    bit.print ch
  skip:
    ;loop
  end:
    stl.loop
}

ch: bit.vec 8, 0
space: bit.vec 8, ' '
