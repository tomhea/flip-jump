// Hello User (#0002)

// Reads a single-line name from stdin (terminated by `\n`) and prints `Hello, <name>!\n`.

main

def main @ read_loop, print_ch, end < ch, nl {
    stl.startup
    stl.output "Hello, "
  read_loop:
    bit.input ch
    bit.if0 8, ch, end
    bit.cmp 8, ch, nl, print_ch, end, print_ch
  print_ch:
    bit.print ch
    ;read_loop
  end:
    stl.output "!\n"
    stl.loop
}

ch: bit.vec 8, 0
nl: bit.vec 8, '\n'
