// Hello Long User (#0015)

// Reads a name and prints "Welcome to FlipJump, <name>! Have a great day!\n".

main

def main @ read_loop, print_ch, end < ch, nl {
    stl.startup
    stl.output "Welcome to FlipJump, "
  read_loop:
    bit.input ch
    bit.if0 8, ch, end
    bit.cmp 8, ch, nl, print_ch, end, print_ch
  print_ch:
    bit.print ch
    ;read_loop
  end:
    stl.output "! Have a great day!\n"
    stl.loop
}

ch: bit.vec 8, 0
nl: bit.vec 8, '\n'
