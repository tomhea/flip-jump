// Substring First 3 (#0187)

// Reads a `\n`-terminated line of at least 3 chars and prints just its first 3 bytes + `\n`.

main

def main < ch {
    stl.startup
    bit.input ch
    bit.print ch
    bit.input ch
    bit.print ch
    bit.input ch
    bit.print ch
    stl.output '\n'
    stl.loop
}

ch: bit.vec 8, 0
