// Is Cli Flag (#1022)

// Reads `\n`-terminated string ≤ 20 chars. Prints `1\n` if it starts with `-` (single-dash flag) OR `--` (long flag), else `0\n`.

main

def main @ yes, no, done < ch, minus {
    stl.startup
    bit.input ch
    bit.cmp 8, ch, minus, no, yes, no       // first char == '-' ?
  yes:
    stl.output "1\n"
    ;done
  no:
    stl.output "0\n"
  done:
    stl.loop
}

ch: bit.vec 8, 0
minus: bit.vec 8, '-'
