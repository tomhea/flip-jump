// Print Alphabet Reversed (#0285)

// No input. Prints `zyxwvutsrqponmlkjihgfedcba\n`.

main

def main @ loop, body, end < ch, before {
    stl.startup
  loop:
    bit.cmp 8, ch, before, end, end, body
  body:
    bit.print ch
    bit.dec 8, ch
    ;loop
  end:
    stl.output '\n'
    stl.loop
}

ch: bit.vec 8, 'z'
before: bit.vec 8, '`'
