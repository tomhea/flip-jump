// Print Alphabet Lower (#0283)

// No input. Prints `abcdefghijklmnopqrstuvwxyz\n`.

main

def main @ loop, body, end < ch, past {
    stl.startup
  loop:
    bit.cmp 8, ch, past, body, end, end
  body:
    bit.print ch
    bit.inc 8, ch
    ;loop
  end:
    stl.output '\n'
    stl.loop
}

ch: bit.vec 8, 'a'
past: bit.vec 8, '{'
