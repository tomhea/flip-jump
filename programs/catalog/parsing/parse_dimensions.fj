// Parse Dimensions (#1400)

// Reads `WxH\n` where `W` and `H` are decimals `0`-`99`. Prints `W * H` + `\n`.

main

def main @ err < wv, hv, prod {
    stl.startup_and_init_all
    hex.input_dec_uint_until 8, wv, 'x', err
    hex.input_dec_uint_until 8, hv, '\n', err
    hex.mul 8, prod, wv, hv
    hex.print_dec_uint 8, prod
    stl.output '\n'
  err:
    stl.loop
}

wv: hex.vec 8
hv: hex.vec 8
prod: hex.vec 8
