// Eval Simple Expr Mul (#0778)

// Reads `<a>*<b>` + `\n` (single digits). Prints `a * b` + `\n`.

main

def main < a, b, op, prod {
    stl.startup_and_init_all
    read_digit a
    hex.input op
    read_digit b
    hex.mul 8, prod, a, b
    hex.print_dec_uint 8, prod
    stl.output '\n'
    stl.loop
}

// Read one ASCII digit and store its value (0-9) in dst[:8].
def read_digit dst < db, c0 {
    hex.input db
    hex.zero 8, dst
    hex.mov 2, dst, db
    hex.sub 8, dst, c0
}

a: hex.vec 8
b: hex.vec 8
op: hex.vec 2
prod: hex.vec 8
db: hex.vec 2
c0: hex.vec 8, '0'
