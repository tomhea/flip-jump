// Parse Time Hhmm (#1390)

// Reads `HH:MM\n` (5 bytes + `\n`). Prints `<H>:<M>\n` with no leading zeros (e.g. `09:05` → `9:5\n`).

main

def main @ err < h, m {
    stl.startup_and_init_all
    hex.input_dec_uint_until 8, h, ':', err
    hex.input_dec_uint_until 8, m, '\n', err
    hex.print_dec_uint 8, h
    stl.output ':'
    hex.print_dec_uint 8, m
    stl.output '\n'
  err:
    stl.loop
}

h: hex.vec 8
m: hex.vec 8
