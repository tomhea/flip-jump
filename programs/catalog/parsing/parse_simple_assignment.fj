// Parse Simple Assignment (#1403)

// Reads `<var>=<value>\n` where `var` is a single lowercase letter and `value` is a decimal `0`-`999`. Prints `<var> is <value>\n`.

main

def main @ err < vbyte, eqb, val {
    stl.startup_and_init_all
    hex.input vbyte
    hex.input eqb
    hex.input_dec_uint_until 8, val, '\n', err
    hex.print vbyte
    stl.output " is "
    hex.print_dec_uint 8, val
    stl.output '\n'
  err:
    stl.loop
}

vbyte: hex.vec 2
eqb: hex.vec 2
val: hex.vec 8
