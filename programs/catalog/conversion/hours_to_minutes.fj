// Hours To Minutes (#0480)

// Reads decimal hours `0`-`24` + `\n` and prints `hours * 60` as decimal + `\n`.

main

def main < value, prod, sixty, input_err {
    stl.startup_and_init_all
    hex.input_dec_uint 4, value, input_err
    hex.mul 4, prod, value, sixty
    hex.print_dec_uint 4, prod
    stl.output '\n'
    stl.loop
}

value: hex.vec 4, 0
prod: hex.vec 4, 0
sixty: hex.vec 4, 60

input_err:
    stl.loop
