// Dollars To Cents (#0364)

// Reads decimal dollars `0`-`99` + `\n` and prints `dollars * 100` as decimal + `\n`.

main

def main < value, prod, hundred, input_err {
    stl.startup_and_init_all
    hex.input_dec_uint 4, value, input_err
    hex.mul 4, prod, value, hundred
    hex.print_dec_uint 4, prod
    stl.output '\n'
    stl.loop
}

value: hex.vec 4, 0
prod: hex.vec 4, 0
hundred: hex.vec 4, 100

input_err:
    stl.loop
