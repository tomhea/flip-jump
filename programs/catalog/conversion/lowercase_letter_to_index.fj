// Lowercase Letter To Index (#0361)

// Reads exactly one byte `a`-`z` and prints its 0-based alphabet index (`a`â†’`0`, ..., `z`â†’`25`) as decimal + `\n`.

main

def main < ch, value, lower_a {
    stl.startup
    bit.input ch
    bit.mov 8, value, ch
    bit.sub 8, value, lower_a
    bit.print_dec_uint 8, value
    stl.output '\n'
    stl.loop
}

ch: bit.vec 8, 0
value: bit.vec 8, 0
lower_a: bit.vec 8, 'a'
