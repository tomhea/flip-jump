// Days To Hours (#0354)

// Reads decimal days `0`-`30` + `\n` and prints `days * 24` as decimal + `\n`.

main

def main < value, prod, twentyfour, input_err {
    stl.startup_and_init_all
    hex.input_dec_uint 4, value, input_err
    hex.mul 4, prod, value, twentyfour
    hex.print_dec_uint 4, prod
    stl.output '\n'
    stl.loop
}

value: hex.vec 4, 0
prod: hex.vec 4, 0
twentyfour: hex.vec 4, 24

input_err:
    stl.loop
