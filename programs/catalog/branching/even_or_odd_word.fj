// Even Or Odd Word (#0204)

// Reads one decimal integer and prints `even\n` or `odd\n` (not `0`/`1`).

main

def main @ odd, done < a, input_err {
    stl.startup_and_init_all
    hex.input_dec_uint 4, a, input_err
    bit.if1 a, odd
    stl.output "even\n"
    ;done
  odd:
    stl.output "odd\n"
  done:
    stl.loop
}

a: hex.vec 4, 0

input_err:
    stl.loop
