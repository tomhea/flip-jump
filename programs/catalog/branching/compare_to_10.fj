// Compare To 10 (#0332)

// Reads one decimal and prints `less\n` if `<10`, `equal\n` if `=10`, `more\n` if `>10`.

main

def main @ less, equal, more, done < a, ten, input_err {
    stl.startup_and_init_all
    hex.input_dec_uint 4, a, input_err
    hex.cmp 4, a, ten, less, equal, more
  less:
    stl.output "less\n"
    ;done
  equal:
    stl.output "equal\n"
    ;done
  more:
    stl.output "more\n"
  done:
    stl.loop
}

a: hex.vec 4, 0
ten: hex.vec 4, 10

input_err:
    stl.loop
