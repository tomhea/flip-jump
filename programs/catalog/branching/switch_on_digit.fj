// Switch On Digit (#0344)

// Reads one ASCII digit `0`-`9` and prints `a\n` for 0, `b\n` for 1, …, `j\n` for 9.

main

def main < ch, zero, lett_a {
    stl.startup
    bit.input ch
    bit.sub 8, ch, zero
    bit.add 8, ch, lett_a
    bit.print ch
    stl.output '\n'
    stl.loop
}

ch: bit.vec 8, 0
zero: bit.vec 8, '0'
lett_a: bit.vec 8, 'a'
