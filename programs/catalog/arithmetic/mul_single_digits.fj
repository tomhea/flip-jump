// Mul Single Digits (#0058)

// Reads two single-digit decimals `0`-`9` (each followed by `\n`) and prints `a * b` as decimal + `\n`.

main

def main < a, b, p, input_err {
    stl.startup_and_init_all
    hex.input_dec_uint 4, a, input_err
    hex.input_dec_uint 4, b, input_err
    hex.mul 4, p, a, b
    hex.print_dec_uint 4, p
    stl.output '\n'
    stl.loop
}

a: hex.vec 4, 0
b: hex.vec 4, 0
p: hex.vec 4, 0

input_err:
    stl.loop
