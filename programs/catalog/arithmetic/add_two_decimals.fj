// Add Two Decimals (#0056)

// Reads two decimal integers (each on its own line) and prints their sum as decimal + `\n`.

main

def main @ err < a, b {
    stl.startup_and_init_all
    hex.input_dec_uint 4, a, err
    hex.input_dec_uint 4, b, err
    hex.add 4, a, b
    hex.print_dec_uint 4, a
    stl.output '\n'
  err:
    stl.loop
}

a: hex.vec 4, 0
b: hex.vec 4, 0
