// Negate Decimal (#0063)

// Reads one signed decimal integer and prints its negation as decimal + `\n`.

main

def main < a, input_err {
    stl.startup_and_init_all
    hex.input_dec_int 4, a, input_err
    hex.neg 4, a
    hex.print_dec_int 4, a
    stl.output '\n'
    stl.loop
}

a: hex.vec 4, 0

input_err:
    stl.loop
