// Cube Small (#0069)

// Reads one decimal integer in `0`-`5` and prints `a * a * a` as decimal + `\n`.

main

def main < a, sq, p, input_err {
    stl.startup_and_init_all
    hex.input_dec_uint 4, a, input_err
    hex.mul 4, sq, a, a
    hex.mul 4, p, sq, a
    hex.print_dec_uint 4, p
    stl.output '\n'
    stl.loop
}

a: hex.vec 4, 0
sq: hex.vec 4, 0
p: hex.vec 4, 0

input_err:
    stl.loop
