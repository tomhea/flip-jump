// Clamp To Max 9 (#0110)

// Reads one decimal in `0`-`99` and prints `min(a, 9)` + `\n` (caps the value at 9).

main

def main @ use_a, use_9, done < a, nine, input_err {
    stl.startup_and_init_all
    hex.input_dec_uint 4, a, input_err
    hex.cmp 4, a, nine, use_a, use_a, use_9
  use_a:
    hex.print_dec_uint 4, a
    ;done
  use_9:
    hex.print_dec_uint 4, nine
  done:
    stl.output '\n'
    stl.loop
}

a: hex.vec 4, 0
nine: hex.vec 4, 9

input_err:
    stl.loop
