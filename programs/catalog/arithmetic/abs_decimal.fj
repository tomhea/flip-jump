// Abs Decimal (#0062)

// Reads one signed decimal integer and prints its absolute value as decimal + `\n`.

main

def main @ do_neg, do_print, err < a {
    stl.startup_and_init_all
    hex.input_dec_int 4, a, err
    hex.sign 4, a, do_neg, do_print
  do_neg:
    hex.neg 4, a
  do_print:
    hex.print_dec_uint 4, a
    stl.output '\n'
  err:
    stl.loop
}

a: hex.vec 4, 0
