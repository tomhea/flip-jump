// Square Small (#0068)

// Reads one decimal integer in `0`-`15` and prints `a * a` as decimal + `\n`.

main

def main < a, p, input_err {
    stl.startup_and_init_all
    hex.input_dec_uint 4, a, input_err
    hex.mul 4, p, a, a
    hex.print_dec_uint 4, p
    stl.output '\n'
    stl.loop
}

a: hex.vec 4, 0
p: hex.vec 4, 0

input_err:
    stl.loop
