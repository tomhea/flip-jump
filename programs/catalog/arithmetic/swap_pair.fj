// Swap Pair (#0098)

// Reads two decimals (each on own line) and prints them in reverse order: `<b>\n<a>\n`.

main

def main < a, b, input_err {
    stl.startup_and_init_all
    hex.input_dec_uint 4, a, input_err
    hex.input_dec_uint 4, b, input_err
    hex.print_dec_uint 4, b
    stl.output '\n'
    hex.print_dec_uint 4, a
    stl.output '\n'
    stl.loop
}

a: hex.vec 4, 0
b: hex.vec 4, 0

input_err:
    stl.loop
