// Complement To 100 (#0114)

// Reads one decimal in `0`-`100` and prints `100 - a` as decimal + `\n`.

main

def main < a, c100, input_err {
    stl.startup_and_init_all
    hex.input_dec_uint 4, a, input_err
    hex.sub 4, c100, a
    hex.print_dec_uint 4, c100
    stl.output '\n'
    stl.loop
}

a: hex.vec 4, 0
c100: hex.vec 4, 100

input_err:
    stl.loop
