// Double Decimal (#0066)

// Reads one decimal integer and prints `a * 2` as decimal + `\n`.

main

def main < a, t, input_err {
    stl.startup_and_init_all
    hex.input_dec_int 4, a, input_err
    hex.mov 4, t, a
    hex.add 4, a, t
    hex.print_dec_int 4, a
    stl.output '\n'
    stl.loop
}

a: hex.vec 4, 0
t: hex.vec 4, 0

input_err:
    stl.loop
