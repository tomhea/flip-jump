// Mul By 10 (#0087)

// Reads one decimal in `0`-`100` and prints `a * 10` as decimal + `\n`.

main

def main < a, k, p, input_err {
    stl.startup_and_init_all
    hex.input_dec_uint 4, a, input_err
    hex.mul 4, p, a, k
    hex.print_dec_uint 4, p
    stl.output '\n'
    stl.loop
}

a: hex.vec 4, 0
k: hex.vec 4, 10
p: hex.vec 4, 0

input_err:
    stl.loop
