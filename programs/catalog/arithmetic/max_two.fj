// Max Two (#0071)

// Reads two decimal integers and prints the larger as decimal + `\n`.

main

def main @ use_a, use_b, done < a, b, input_err {
    stl.startup_and_init_all
    hex.input_dec_uint 4, a, input_err
    hex.input_dec_uint 4, b, input_err
    hex.cmp 4, a, b, use_b, use_b, use_a
  use_a:
    hex.print_dec_uint 4, a
    ;done
  use_b:
    hex.print_dec_uint 4, b
  done:
    stl.output '\n'
    stl.loop
}

a: hex.vec 4, 0
b: hex.vec 4, 0

input_err:
    stl.loop
