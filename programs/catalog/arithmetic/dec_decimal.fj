// Dec Decimal (#0065)

// Reads one decimal integer and prints `a - 1` as decimal + `\n`.

main

def main < a, input_err {
    stl.startup_and_init_all
    hex.input_dec_int 4, a, input_err
    hex.dec 4, a
    hex.print_dec_int 4, a
    stl.output '\n'
    stl.loop
}

a: hex.vec 4, 0

input_err:
    stl.loop
