// Add Three Decimals (#0061)

// Reads three decimal integers (each own line) and prints their sum + `\n`.

main

def main < a, b, c, input_err {
    stl.startup_and_init_all
    hex.input_dec_uint 4, a, input_err
    hex.input_dec_uint 4, b, input_err
    hex.input_dec_uint 4, c, input_err
    hex.add 4, a, b
    hex.add 4, a, c
    hex.print_dec_uint 4, a
    stl.output '\n'
    stl.loop
}

a: hex.vec 4, 0
b: hex.vec 4, 0
c: hex.vec 4, 0

input_err:
    stl.loop
