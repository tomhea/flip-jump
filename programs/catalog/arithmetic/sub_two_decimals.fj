// Sub Two Decimals (#0057)

// Reads two decimal integers (each on its own line) and prints `a - b` as a signed decimal + `\n`.

main

def main < a, b, input_err {
    stl.startup_and_init_all
    hex.input_dec_int 4, a, input_err
    hex.input_dec_int 4, b, input_err
    hex.sub 4, a, b
    hex.print_dec_int 4, a
    stl.output '\n'
    stl.loop
}

a: hex.vec 4, 0
b: hex.vec 4, 0

input_err:
    stl.loop
