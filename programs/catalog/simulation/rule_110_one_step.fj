    ;dn5
  r000_5:
    hex.set 2, ca_n5, 0
  dn5:
    hex.if0 2, ca_c5, lz6
    hex.if0 2, ca_c6, c10_6
    hex.if0 2, ca_c7, r110_6
    hex.set 2, ca_n6, 0
    ;dn6
  r110_6:
    hex.set 2, ca_n6, 1
    ;dn6
  c10_6:
    hex.if0 2, ca_c7, r100_6
    hex.set 2, ca_n6, 1
    ;dn6
  r100_6:
    hex.set 2, ca_n6, 0
    ;dn6
  lz6:
    hex.if0 2, ca_c6, c00_6
    hex.if0 2, ca_c7, r010_6
    hex.set 2, ca_n6, 1
    ;dn6
  r010_6:
    hex.set 2, ca_n6, 1
    ;dn6
  c00_6:
    hex.if0 2, ca_c7, r000_6
    hex.set 2, ca_n6, 1
    ;dn6
  r000_6:
    hex.set 2, ca_n6, 0
  dn6:
    hex.if0 2, ca_c6, lz7
    hex.if0 2, ca_c7, c10_7
    hex.if0 2, ca_c0, r110_7
    hex.set 2, ca_n7, 0
    ;dn7
  r110_7:
    hex.set 2, ca_n7, 1
    ;dn7
  c10_7:
    hex.if0 2, ca_c0, r100_7
    hex.set 2, ca_n7, 1
    ;dn7
  r100_7:
    hex.set 2, ca_n7, 0
    ;dn7
  lz7:
    hex.if0 2, ca_c7, c00_7
    hex.if0 2, ca_c0, r010_7
    hex.set 2, ca_n7, 1
    ;dn7
  r010_7:
    hex.set 2, ca_n7, 1
    ;dn7
  c00_7:
    hex.if0 2, ca_c0, r000_7
    hex.set 2, ca_n7, 1
    ;dn7
  r000_7:
    hex.set 2, ca_n7, 0
  dn7:
    hex.add 2, ca_n0, zero_char
    hex.print ca_n0
    hex.add 2, ca_n1, zero_char
    hex.print ca_n1
    hex.add 2, ca_n2, zero_char
    hex.print ca_n2
    hex.add 2, ca_n3, zero_char
    hex.print ca_n3
    hex.add 2, ca_n4, zero_char
    hex.print ca_n4
    hex.add 2, ca_n5, zero_char
    hex.print ca_n5
    hex.add 2, ca_n6, zero_char
    hex.print ca_n6
    hex.add 2, ca_n7, zero_char
    hex.print ca_n7
    stl.output '\n'
  err:
    stl.loop
}

ca_c0: hex.vec 2
ca_c1: hex.vec 2
ca_c2: hex.vec 2
ca_c3: hex.vec 2
ca_c4: hex.vec 2
ca_c5: hex.vec 2
ca_c6: hex.vec 2
ca_c7: hex.vec 2
ca_n0: hex.vec 2
ca_n1: hex.vec 2
ca_n2: hex.vec 2
ca_n3: hex.vec 2
ca_n4: hex.vec 2
ca_n5: hex.vec 2
