    hex.if0 2, ca_c5, r000_4
    hex.set 2, ca_n4, 1
    ;dn4
  r000_4:
    hex.set 2, ca_n4, 0
  dn4:
    hex.if0 2, ca_c4, lz5
    hex.if0 2, ca_c5, c10_5
    hex.if0 2, ca_c6, r110_5
    hex.set 2, ca_n5, 0
    ;dn5
  r110_5:
    hex.set 2, ca_n5, 1
