// Isolate Lowest Set Bit (#0934)

// Reads one byte and outputs `byte AND (-byte mod 256)` (keeps only the lowest set bit) as one raw byte. For `byte = 0` outputs `0`.

main

def main < ch, tmp {
    stl.startup
    bit.input ch
    bit.mov 8, tmp, ch
    bit.not 8, tmp
    bit.inc 8, tmp
    bit.and 8, ch, tmp
    bit.print ch
    stl.loop
}

ch: bit.vec 8, 0
tmp: bit.vec 8, 0
