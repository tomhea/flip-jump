// Is Byte Full (#0375)

// Reads one byte and prints `1\n` if it equals `0xFF`, else `0\n`.

main

def main @ yes, no, done < ch, full {
    stl.startup
    bit.input ch
    bit.cmp 8, ch, full, no, yes, no
  yes:
    stl.output "1\n"
    ;done
  no:
    stl.output "0\n"
  done:
    stl.loop
}

ch: bit.vec 8, 0
full: bit.vec 8, 0xff
