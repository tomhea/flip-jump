// Prev Power Of 2 Byte (#0927)

// Reads one byte `1`-`255` and outputs the largest power of 2 that is `<=` the input (`5` → `4`, `8` → `8`) as one raw byte.

main

def main @ loop, grow, done < ch, p, p2 {
    stl.startup
    bit.input ch
    bit.zero 8, p
    bit.inc 8, p
  loop:
    bit.mov 8, p2, p
    bit.shl 8, p2
    bit.cmp 8, p2, ch, grow, grow, done
  grow:
    bit.shl 8, p
    ;loop
  done:
    bit.print p
    stl.loop
}

ch: bit.vec 8, 0
p: bit.vec 8, 0
p2: bit.vec 8, 0
