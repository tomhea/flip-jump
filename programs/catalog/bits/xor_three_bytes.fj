// Xor Three Bytes (#0221)

// Reads exactly 3 bytes. Outputs `b1 XOR b2 XOR b3` as one raw byte.

main

def main < a, b, c {
    stl.startup
    bit.input a
    bit.input b
    bit.input c
    bit.xor 8, a, b
    bit.xor 8, a, c
    bit.print a
    stl.loop
}

a: bit.vec 8, 0
b: bit.vec 8, 0
c: bit.vec 8, 0
