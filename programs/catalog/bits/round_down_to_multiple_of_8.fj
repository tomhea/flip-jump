// Round Down To Multiple Of 8 (#0932)

// Reads one byte `0`-`255` and outputs the largest multiple of 8 that is `<=` the input (`0` → `0`, `9` → `8`, `15` → `8`) as one raw byte.

main

def main < ch {
    stl.startup
    bit.input ch
    bit.zero ch + 0*dw
    bit.zero ch + 1*dw
    bit.zero ch + 2*dw
    bit.print ch
    stl.loop
}

ch: bit.vec 8, 0
