// Max Two Bytes (#0898)

// Reads exactly 2 bytes. Outputs the byte with larger numeric value as a raw byte.

main

def main @ use_a, use_b, done < a, b {
    stl.startup
    bit.input a
    bit.input b
    bit.cmp 8, a, b, use_b, use_b, use_a
  use_a:
    bit.print a
    ;done
  use_b:
    bit.print b
  done:
    stl.loop
}

a: bit.vec 8, 0
b: bit.vec 8, 0
